{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "python3 -m pip install --disable-pip-version-check -r requirements.txt -t python_deps",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{finals-flashcards-csvs/**,apps/flashcards/**,python_deps/**}"
    }
  },
  "env": {
    "PYTHONPATH": "."
  }
}
