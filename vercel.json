{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r api/requirements.txt",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{finals-flashcards-csvs/**,apps/flashcards/**}"
    }
  },
  "env": {
    "PYTHONPATH": "."
  }
}
